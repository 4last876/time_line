#include <iostream>
#include <fstream>
#include <string>
#include <list>
#include <sstream>
#include "json.hpp"

#include <SDL2/SDL.h>
#include <SDL2/SDL_image.h>

#define NK_INCLUDE_FIXED_TYPES
#define NK_INCLUDE_STANDARD_IO
#define NK_INCLUDE_STANDARD_VARARGS
#define NK_INCLUDE_DEFAULT_ALLOCATOR
#define NK_INCLUDE_VERTEX_BUFFER_OUTPUT
#define NK_INCLUDE_FONT_BAKING
#define NK_INCLUDE_DEFAULT_FONT
#define NK_IMPLEMENTATION
#define NK_SDL_RENDERER_IMPLEMENTATION
#include "nuklear.h"
#include "nuklear_sdl_renderer.h"

int WINDOW_WIDTH;
int WINDOW_HEIGHT;

int DISTANCE_BETWEEN = 100;

int SIZE_TEXT = 20;

int GROUP_WIDTH = 330;
int GROUP_HEIGHT = 330;

class TimeLineModel{
using value_type = std::tuple<std::string,std::string,std::string>;

std::vector<value_type> data;
    public:
TimeLineModel() = default;

void load(std::vector<value_type>& data_){
data = data_;
}

bool data_is_empty(){
    return data.empty();
}

std::vector<value_type>::iterator begin(){
return data.begin();
}

std::vector<value_type>::iterator end(){
return data.end();
}

};

class IMG_convert{
std::shared_ptr<SDL_Renderer> render;
    public:
    IMG_convert(std::shared_ptr<SDL_Renderer> render_) : render {render_}{}

    SDL_Texture* ImgTexture(std::string path){
    SDL_Surface* loaded = IMG_Load(path.c_str());
     if(loaded == nullptr){
        std::cout << "Error: " << SDL_GetError() << std::endl;
        throw std::runtime_error(SDL_GetError());
     }
     SDL_Texture* texture = SDL_CreateTextureFromSurface(render.get(),loaded);
 
      if(!texture){
        std::cout << "текстура не действительна "<< SDL_GetError() << std::endl;
        throw std::runtime_error("текстура не действительна ");
      }
     SDL_FreeSurface(loaded);
     return texture;
    }
};

class Resource{
std::shared_ptr<IMG_convert> img_loader;
std::string title;
std::string text;

struct nk_image image;

SDL_Texture* texture;


    public:

struct nk_rect size;

    Resource(std::shared_ptr<SDL_Renderer> render,std::tuple<std::string,std::string,std::string>& resorces) : title{std::get<0>(resorces)},text{std::get<1>(resorces)}{
       img_loader = std::make_shared<IMG_convert>(render);
       texture = img_loader->ImgTexture(std::get<2>(resorces));
       image = nk_image_ptr(texture);

       size = {0,0,GROUP_WIDTH,GROUP_HEIGHT};
    }

    SDL_Texture* getTexture(){
        return texture;
    }

    struct nk_image getImage(){
        return image;
    }

    std::string getTitle(){
        return title;
    }

    std::string getText(){
        return text;
    }



    ~Resource(){
        SDL_DestroyTexture(texture);
    }
};

class ResourceManager{
std::shared_ptr<SDL_Renderer> render;
std::list<Resource> resources;

   public:
    ResourceManager(std::shared_ptr<SDL_Renderer> render_) : render{render_}{}

    void initResorces(){
    int distance = 0;
    for(auto& res : resources){
        res.size.x = distance;
        distance += (res.size.w + DISTANCE_BETWEEN);
    }
}

    void loadResorces(std::shared_ptr<TimeLineModel> tlModel){
        resources.clear();
       for( auto& res : *tlModel){
         resources.emplace_back(render,res);
       }
       initResorces();
    }

    int getSize(){
        return resources.size();
    }

    std::list<Resource>& getResource(){
        return resources;
    }
};

class TimeLineController;
//VIEW 

class ITimeLineGui{

    public:
    virtual ~ITimeLineGui(){}
    virtual void show() = 0;
    virtual bool is_open() = 0;
    virtual void close() = 0;
    virtual void loadResorces(std::shared_ptr<TimeLineModel> tlModel) = 0;
    virtual void pollEvent(TimeLineController& controlle) = 0;
}; 

class TimeLineSDL : public ITimeLineGui {
     static void Destroy_renderer(SDL_Renderer* rend){
     SDL_DestroyRenderer(rend);
    }

   static void Destroy_window(SDL_Window* win){
     SDL_DestroyWindow(win);
    }

    std::shared_ptr<SDL_Window> win;
    std::shared_ptr<SDL_Renderer> renderer;
    std::shared_ptr<ResourceManager> resorceManager;
    std::vector<SDL_Texture*> textures;

    struct nk_context *ctx;
    struct nk_command_buffer *canvas;
    struct nk_colorf bg;
    bool running = 1;
    float font_scale = 1;

 public:
 TimeLineSDL(){
        win.reset(SDL_CreateWindow("win",
        SDL_WINDOWPOS_UNDEFINED, SDL_WINDOWPOS_UNDEFINED,
        0, 0, SDL_WINDOW_SHOWN|SDL_WINDOW_ALLOW_HIGHDPI|SDL_WINDOW_FULLSCREEN_DESKTOP),Destroy_window);
        SDL_GetWindowSize(win.get(), &WINDOW_WIDTH, &WINDOW_HEIGHT);

    if (win.get() == nullptr) {
        std::stringstream ss;
        ss << "Error SDL_CreateWindow "<< SDL_GetError() << std::endl;
        throw std::runtime_error(ss.str());
    }

    renderer.reset(SDL_CreateRenderer(win.get(), -1, SDL_RENDERER_ACCELERATED),Destroy_renderer);

    if (renderer.get() == nullptr) {
        std::stringstream ss;
        ss << "Error SDL_CreateRenderer "<< SDL_GetError() << std::endl;;
        throw std::runtime_error(ss.str());
    }

    //init Nucklear
    ctx = nk_sdl_init(win.get(), renderer.get());

    resorceManager = std::make_shared<ResourceManager>(renderer);

    initFont();
 }

~TimeLineSDL(){
    for(auto& ptr : textures){
        SDL_DestroyTexture(ptr);
        }
}

    void initFont(){
        struct nk_font_atlas *atlas;
        struct nk_font_config config = nk_font_config(SIZE_TEXT);
        config.oversample_h = 1;
        config.oversample_v = 1;
        config.range = nk_font_cyrillic_glyph_ranges();
        
   
        nk_sdl_font_stash_begin(&atlas);
        struct nk_font *font = nk_font_atlas_add_from_file(atlas, "font.ttf", SIZE_TEXT, &config);
        nk_sdl_font_stash_end();
        nk_style_set_font(ctx, &font->handle); 


        font->handle.height /= font_scale;
        nk_style_set_font(ctx, &font->handle);
    }

    void loadResorces(std::shared_ptr<TimeLineModel> tlModel) override{
       resorceManager->loadResorces(tlModel);
    }


    void show() override{
if (nk_begin(ctx, "Demo", nk_rect(0, 0, WINDOW_WIDTH, WINDOW_HEIGHT),0))
{
           canvas = nk_window_get_canvas(ctx);

           nk_layout_space_begin(ctx, NK_STATIC, WINDOW_HEIGHT, resorceManager->getSize());

            struct nk_window *win = ctx->current;
            float scroll_y = win->scrollbar.y;
           
            nk_stroke_line(canvas,0,(WINDOW_HEIGHT  / 2) - scroll_y,WINDOW_WIDTH,(WINDOW_HEIGHT / 2) - scroll_y,1,nk_rgb(255, 255, 255));

           for(auto it = resorceManager->getResource().begin(); it != resorceManager->getResource().end(); ++it){
            auto& resource = *it;
            struct nk_rect resize {resource.size};
            resize.y = (WINDOW_HEIGHT / 2) - (GROUP_HEIGHT / 2);

            nk_layout_space_push(ctx,{0,0,50,50});

            nk_layout_space_push(ctx,resize);
            if (nk_group_begin(ctx, resource.getTitle().c_str(), NK_WINDOW_BORDER | NK_WINDOW_NO_SCROLLBAR)) {
            nk_layout_row_dynamic(ctx,150, 1);
            nk_image(ctx,resource.getImage());
            nk_layout_row_dynamic(ctx,30, 1);
            nk_label_wrap(ctx,resource.getTitle().c_str());
            nk_layout_row_dynamic(ctx,150, 1);
            nk_label_wrap(ctx,resource.getText().c_str());
            nk_group_end(ctx);
              }
            }

           nk_layout_space_end(ctx);
           }
        nk_end(ctx);

if (nk_begin(ctx, "DEBUG", nk_rect(0, 0, 200, 200),NK_WINDOW_BORDER|NK_WINDOW_MOVABLE|NK_WINDOW_SCALABLE|NK_WINDOW_MINIMIZABLE|NK_WINDOW_TITLE)){
nk_layout_row_dynamic(ctx,20,1);
nk_property_int(ctx, "DISTANCE_BETWEEN:", 0, &DISTANCE_BETWEEN, 500, 10, 1);
if(nk_button_label(ctx,"ok")){
    resorceManager->initResorces();
}

nk_property_int(ctx, "SIZE TEXT:",5, &SIZE_TEXT, 50, 1, 1);
if(nk_button_label(ctx,"ok")){
    initFont();
}

}
nk_end(ctx);


        SDL_SetRenderDrawColor(renderer.get(), bg.r * 255, bg.g * 255, bg.b * 255, bg.a * 255);
        SDL_RenderClear(renderer.get());

        nk_sdl_render(NK_ANTI_ALIASING_ON);

        SDL_RenderPresent(renderer.get());
    }

    bool is_open() override{
        return running;
    }
    void close() override{
        running = 0;
    }
    void pollEvent(TimeLineController& controlle) override{
        SDL_Event evt;
        nk_input_begin(ctx);
        while (SDL_PollEvent(&evt)) {
            if (evt.type == SDL_QUIT) close();
            if(evt.type == SDL_KEYDOWN && evt.key.keysym.sym == SDLK_ESCAPE)close();
            nk_sdl_handle_event(&evt);
        }
        nk_sdl_handle_grab(); 
        nk_input_end(ctx);
    }
};

//MODEL
class IRead{
    public:
  virtual ~IRead() = default;
  virtual  std::string read(std::string path ) = 0;
};

class Read2File : public IRead{
public:
    Read2File() = default;

    std::string read(std::string path) override{
       std::ifstream fi{path};
        if(!fi.is_open()){
            throw std::runtime_error("файл не открыт");
            }
        std::string buffer{std::istreambuf_iterator<char>(fi),{}};
        fi.close();
        return buffer;
    }
};

class IExtractConfig{

    public: 
    virtual ~IExtractConfig() = default;

    virtual void parse(std::string idata) = 0;

    virtual std::vector<std::tuple<std::string,std::string,std::string>> extract() = 0;
};

class ExtractConfigJson : public IExtractConfig{
nlohmann::json json;

public:

 void parse(std::string idata) override{
       json = nlohmann::json::parse(idata);
 }

 std::vector<std::tuple<std::string,std::string,std::string>> extract() override{
    std::vector<std::tuple<std::string,std::string,std::string>> rdata;
          for(auto& elem : json){
            auto tuple = std::make_tuple(elem["title"].get<std::string>(),elem["text"].get<std::string>(),elem["path"].get<std::string>());
            rdata.push_back(tuple);
        }
    return rdata;
 }

};


//CONTROLLLER
class LoaderTimeLineModel{
std::shared_ptr<IRead> read;
std::shared_ptr<IExtractConfig> cfg;
   public:
LoaderTimeLineModel(std::shared_ptr<IRead> read_,std::shared_ptr<IExtractConfig> cfg_) : read{read_},cfg{cfg_}{}

std::vector<std::tuple<std::string,std::string,std::string>> load(std::string path ){
std::vector<std::tuple<std::string,std::string,std::string>> data;

    auto res = read->read(path);
    cfg->parse(res);
    auto vec = cfg->extract();
    for(const auto& val : vec){
        auto&[a,b,c] = val;
        data.push_back(std::make_tuple(a,b,c));
    }
    return data;
}

};


class TimeLineController{ 
  std::shared_ptr<LoaderTimeLineModel> loaderJSON;
  std::shared_ptr<TimeLineModel> tlModel;
  std::shared_ptr<ITimeLineGui> gui;
    bool running = 1;

    public:
    TimeLineController(std::string path){
    loaderJSON = std::make_shared<LoaderTimeLineModel>(std::make_shared<Read2File>(),std::make_shared<ExtractConfigJson>());
    tlModel = std::make_shared<TimeLineModel>();
    gui = std::make_shared<TimeLineSDL>();
    loadcfg(path);
    }

    void loadcfg(std::string path){
        auto data = (*loaderJSON).load(path);
        (*tlModel).load(data);
    }

    

    void run(){

        gui->loadResorces(tlModel);
        while(gui->is_open()){
            gui->show();
            gui->pollEvent(*this);
        }
    }

};


int main(){
SDL_SetHint(SDL_HINT_VIDEO_HIGHDPI_DISABLED, "0");
SDL_Init(SDL_INIT_VIDEO);

int flagsIMG = IMG_INIT_JPG | IMG_INIT_PNG;
        if ((IMG_Init(flagsIMG) & flagsIMG) != flagsIMG) {
        std::stringstream ss;
        ss << "Error  "<< SDL_GetError() << std::endl;;
        throw std::runtime_error(ss.str());
     }   

try{

     TimeLineController cr("conf.json");
     cr.run();

}catch(std::exception& e){
std::cerr << e.what() << std::endl;
}
     SDL_Quit();
}
